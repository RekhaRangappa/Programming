function reverseString(data) {
    let reverse = '';
    for(let i = data.length-1; i>=0 ; i--) {
        reverse += data[i];
    }
    return reverse;
}


let str = "ILoveLihan";
const ans = [...str].reverse().join("");
console.log(ans);

let result = reverseString("Elephant");
console.log(result);